# X/Twitter API credentials
# Get a bearer token at https://developer.x.com
NUXT_X_BEARER_TOKEN=your_bearer_token_here
NUXT_PUBLIC_X_USERNAME=your_x_handle_here

# Umami analytics proxy
NUXT_UMAMI_PROXY_TARGET=https://track.aldas.dev
NUXT_PUBLIC_UMAMI_WEBSITE_ID=db0fe301-1e73-4e0e-b227-aa45eda1e015

# Nuxt Studio - GitHub OAuth (for editing content in production)
# Create OAuth app at: https://github.com/settings/developers
# Set callback URL to: https://your-domain.com/__nuxt_studio/auth/github
STUDIO_GITHUB_CLIENT_ID=your_github_oauth_client_id
STUDIO_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
